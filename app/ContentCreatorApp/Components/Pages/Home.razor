    private async Task RestaurarHistoricoPlayerAsync()
    {
        var storageKey = PlayerHistoryStorageKey;
        if (Session is null || string.IsNullOrWhiteSpace(storageKey))
        {
            PlayerHistoryIds = [];
            return;
        }

        await LimparHistoricoLegadoAsync();

        var historyJson = await Js.InvokeAsync<string?>("localStorage.getItem", storageKey);
        if (string.IsNullOrWhiteSpace(historyJson))
        {
            PlayerHistoryIds = [];
            return;
        }

        var ids = LerHistoricoDoUsuarioAtual(historyJson);
        var existingIds = Conteudos.Select(conteudo => conteudo.Id).ToHashSet();
        PlayerHistoryIds = ids
            .Where(existingIds.Contains)
            .Distinct()
            .Take(ItemsPerPage)
            .ToList();
    }

    private async Task SalvarHistoricoPlayerAsync(Conteudo conteudo)
    {
        var storageKey = PlayerHistoryStorageKey;
        if (Session is null || string.IsNullOrWhiteSpace(storageKey))
        {
            return;
        }

        PlayerHistoryIds.Remove(conteudo.Id);
        PlayerHistoryIds.Insert(0, conteudo.Id);
        PlayerHistoryIds = PlayerHistoryIds
            .Distinct()
            .Take(ItemsPerPage)
            .ToList();

        var cache = new PlayerHistoryCache(Session.Usuario.Id, PlayerHistoryIds);
        var historyJson = System.Text.Json.JsonSerializer.Serialize(cache);
        await LimparHistoricoLegadoAsync();
        await Js.InvokeVoidAsync("localStorage.setItem", storageKey, historyJson);
    }

    private void ResetarEstadoDeUsuarioAtual()
    {
        PlayerHistoryIds = [];
        ConteudoEmReproducao = null;
        ReproducaoAtual = null;
        CineDestaque = null;
    }

    private async Task LimparHistoricoLegadoAsync()
    {
        await Js.InvokeVoidAsync("localStorage.removeItem", PlayerHistoryStorageBaseKey);
    }

    private List<int> LerHistoricoDoUsuarioAtual(string historyJson)
    {
        if (Session is null)
        {
            return [];
        }

        try
        {
            if (historyJson.TrimStart().StartsWith("[", StringComparison.Ordinal))
            {
                return System.Text.Json.JsonSerializer.Deserialize<List<int>>(historyJson) ?? [];
            }

            var cache = System.Text.Json.JsonSerializer.Deserialize<PlayerHistoryCache>(
                historyJson,
                new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)
                {
                    PropertyNameCaseInsensitive = true
                });

            return cache?.UsuarioId == Session.Usuario.Id
                ? cache.ConteudoIds ?? []
                : [];
        }
        catch (System.Text.Json.JsonException)
        {
            return [];
        }
    }

