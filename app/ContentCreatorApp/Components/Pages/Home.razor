    private void DefinirConteudoParaPlaylist(int playlistId, object? value)
    {
        ConteudoPorPlaylist[playlistId] = int.TryParse(value?.ToString(), out var id) ? id : 0;
    }

    private int ConteudoSelecionadoParaPlaylist(int playlistId) =>
        ConteudoPorPlaylist.TryGetValue(playlistId, out var id) ? id : 0;

    private async Task RunAsync(Func<Task> action)
    {
        Busy = true;
        try
        {
            await action();
        }
        catch (StreamingApiException ex) when (ex.StatusCode == 401)
        {
            await LogoutAsync();
            SetError("Sessao expirada ou token invalido. Faca login novamente.");
        }
        catch (Exception ex)
        {
            SetError(ex.Message);
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task PersistAuthAsync()
    {
        if (Session is null)
        {
            return;
        }

        var json = System.Text.Json.JsonSerializer.Serialize(
            Session,
            new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
        await Js.InvokeVoidAsync("localStorage.setItem", AuthStorageKey, json);
    }

    private string Token => Session?.Token ?? string.Empty;

    private string TabClass(string section) => ActiveSection == section ? "active" : string.Empty;

    private string FilterChipClass(string category) => CineCategoria == category ? "active" : string.Empty;

    private string UsuarioNome(int id) => Usuarios.FirstOrDefault(usuario => usuario.Id == id)?.Nome ?? $"Usuario #{id}";

    private string CriadorNome(int id) => Criadores.FirstOrDefault(criador => criador.Id == id)?.Nome ?? $"Criador #{id}";

    private string ConteudoTitulo(int id) => Conteudos.FirstOrDefault(conteudo => conteudo.Id == id)?.Titulo ?? $"Conteudo #{id}";

    private static int TotalPages(int count) =>
        Math.Max(1, (int)Math.Ceiling(count / (double)ItemsPerPage));

    private static int ClampPage(int page, int totalPages) =>
        Math.Min(Math.Max(page, 1), Math.Max(totalPages, 1));

    private static List<T> Paginar<T>(IReadOnlyList<T> items, int page) =>
        items
            .Skip((ClampPage(page, TotalPages(items.Count)) - 1) * ItemsPerPage)
            .Take(ItemsPerPage)
            .ToList();

    private bool IsVideo(Conteudo? conteudo) => NormalizeTipo(conteudo?.Tipo) == "video";

    private bool PassaFiltroCine(Conteudo conteudo)
    {
        if (CineCriadorId > 0 && conteudo.CriadorId != CineCriadorId)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(CineBusca))
        {
            var termo = CineBusca.Trim();
            var tituloOk = conteudo.Titulo.Contains(termo, StringComparison.OrdinalIgnoreCase);
            var criadorOk = (conteudo.Criador?.Nome ?? CriadorNome(conteudo.CriadorId))
                .Contains(termo, StringComparison.OrdinalIgnoreCase);

            if (!tituloOk && !criadorOk)
            {
                return false;
            }
        }

        return CineCategoria switch
        {
            "prontos" => IsPlayableMedia(conteudo),
            "com-arquivo" => HasMediaFallback(conteudo),
            "sem-arquivo" => !HasMediaFallback(conteudo),
            _ => true
        };
    }

    private bool IsAudio(Conteudo? conteudo)
    {
        var tipo = NormalizeTipo(conteudo?.Tipo);
        return tipo is "musica" or "podcast" or "audio";
    }

    private bool IsSupportedMedia(Conteudo conteudo) => IsVideo(conteudo) || IsAudio(conteudo);

    private bool IsPlayableMedia(Conteudo conteudo) =>
        IsSupportedMedia(conteudo) &&
        (conteudo.DisponivelParaReproducao ||
         !string.IsNullOrWhiteSpace(conteudo.UrlReproducao) ||
         HasMediaFallback(conteudo));

    private bool HasMediaFallback(Conteudo conteudo) =>
        !string.IsNullOrWhiteSpace(conteudo.UrlMidia) ||
        !string.IsNullOrWhiteSpace(conteudo.ArquivoMidia);

    private string MediaKindLabel(Conteudo? conteudo)
    {
        if (IsVideo(conteudo))
        {
            return "Video";
        }

        var tipo = NormalizeTipo(conteudo?.Tipo);
        if (tipo == "podcast")
        {
            return "Podcast";
        }

        if (tipo is "musica" or "audio")
        {
            return "Musica";
        }

        return "Midia";
    }

    private string MediaIcon(Conteudo? conteudo)
    {
        var tipo = NormalizeTipo(conteudo?.Tipo);
        if (tipo == "podcast")
        {
            return "CAST";
        }

        if (tipo is "musica" or "audio")
        {
            return "MP3";
        }

        return "PLAY";
    }

    private string? BuildPlayerSource(Conteudo? conteudo)
    {
        if (conteudo is null)
        {
            return null;
        }

        if (IsVideo(conteudo))
        {
            return AbsolutizarUrl(ReproducaoAtual?.UrlStream)
                ?? AbsolutizarUrl(conteudo.UrlReproducao)
                ?? MediaUrl(conteudo);
        }

        return MediaUrl(conteudo)
            ?? AbsolutizarUrl(conteudo.UrlReproducao)
            ?? AbsolutizarUrl(ReproducaoAtual?.UrlStream);
    }

    private string? CinePreviewSource(Conteudo conteudo) =>
        AbsolutizarUrl(conteudo.UrlReproducao) ?? MediaUrl(conteudo);

    private static string PreviewId(Conteudo conteudo) => $"cine-preview-{conteudo.Id}";

    private static string CineCardStyle(Conteudo conteudo)
    {
        var palette = conteudo.Id % 4;
        return palette switch
        {
            0 => "--cine-accent:#dc2626;--cine-glow:rgba(220,38,38,.32);",
            1 => "--cine-accent:#facc15;--cine-glow:rgba(250,204,21,.26);",
            2 => "--cine-accent:#ef4444;--cine-glow:rgba(239,68,68,.3);",
            _ => "--cine-accent:#991b1b;--cine-glow:rgba(153,27,27,.34);"
        };
    }

    private static string NormalizeTipoLegacy(string? tipo) =>
        (tipo ?? string.Empty)
            .Trim()
            .ToLowerInvariant()
            .Replace("ú", "u")
            .Replace("ù", "u")
            .Replace("ü", "u")
            .Replace("á", "a")
            .Replace("à", "a")
            .Replace("ã", "a")
            .Replace("â", "a")
            .Replace("é", "e")
            .Replace("ê", "e")
            .Replace("í", "i")
            .Replace("ó", "o")
            .Replace("ô", "o")
            .Replace("õ", "o")
            .Replace("ç", "c");

    private static string NormalizeTipo(string? tipo)
    {
        var normalized = (tipo ?? string.Empty)
            .Trim()
            .ToLowerInvariant()
            .Normalize(System.Text.NormalizationForm.FormD);
        var builder = new System.Text.StringBuilder(normalized.Length);

        foreach (var character in normalized)
        {
            var category = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(character);
            if (category != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                builder.Append(character);
            }
        }

        return builder.ToString().Normalize(System.Text.NormalizationForm.FormC);
    }

    private string? MediaUrl(Conteudo conteudo)
    {
        if (!string.IsNullOrWhiteSpace(conteudo.UrlMidia))
        {
            return AbsolutizarUrl(conteudo.UrlMidia);
        }

        return string.IsNullOrWhiteSpace(conteudo.ArquivoMidia)
            ? null
            : $"{ApiBaseUrl.Trim().TrimEnd('/')}/Media/{Uri.EscapeDataString(conteudo.ArquivoMidia)}";
    }

    private string? AbsolutizarUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        if (Uri.TryCreate(url, UriKind.Absolute, out _))
        {
            return url;
        }

        return $"{ApiBaseUrl.Trim().TrimEnd('/')}/{url.TrimStart('/')}";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0)
        {
            return "0 MB";
        }

        var mb = bytes / 1024d / 1024d;
        return $"{mb:0.##} MB";
    }

    private void SetStatus(string message)
    {
        StatusMessage = message;
        IsError = false;
    }

    private void SetError(string message)
    {
        StatusMessage = message;
        IsError = true;
    }

    private sealed record PlayerHistoryCache(int UsuarioId, List<int> ConteudoIds);
}
