@page "/"
@rendermode InteractiveServer
@inject StreamingApiClient Api
@inject IJSRuntime Js
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Paqueta's Streaming</PageTitle>

<div id="opening-screen" class="opening-screen" data-audio-src="/audio/opening.mp3">
    <div class="opening-rays" aria-hidden="true"></div>
    <div class="opening-logo" aria-label="Paqueta Streaming">
        <span>PS</span>
        <strong>PAQUETA</strong>
        <small>STREAMING</small>
    </div>
    <button type="button" class="opening-sound" hidden>Entrar</button>
</div>

<main class="app-shell">
    <header class="topbar flamengo-hero">
        <div class="brand-copy">
            <h1>PAQUETA'S STREAMING</h1>
            <p class="subtitle">
                Saudacoes rubro-negras: bem-vindo ao seu novo streaming favorito para criar,
                assistir e organizar conteudos com energia de final em noite de Maracana.
            </p>
        </div>

        <div class="hero-side">
            <div class="flag-stage" aria-hidden="true">
                <div class="waving-flag">
                    <span>PS</span>
                    <i></i>
                    <i></i>
                    <i></i>
                </div>
                <div class="signal-rings">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
        </div>
    </header>

    @if (!IsReady)
    {
        <section class="state-panel">
            <strong>Carregando front...</strong>
            <span>Preparando sessao local e configuracao da API.</span>
        </section>
    }
    else if (Session is null)
    {
        <section class="auth-layout">
            <form class="panel auth-panel stadium-panel" @onsubmit="CadastrarAsync" @onsubmit:preventDefault="true">
                <div class="panel-title">
                    <span>01</span>
                    <h2>Criar usuario</h2>
                </div>
                <label>
                    Nome
                    <input @bind="Cadastro.Nome" required autocomplete="name" />
                </label>
                <label>
                    E-mail
                    <input type="email" @bind="Cadastro.Email" required autocomplete="email" />
                </label>
                <label>
                    Senha
                    <input type="password" @bind="Cadastro.Senha" required autocomplete="new-password" />
                </label>
                <button class="primary-action" type="submit" disabled="@Busy">Cadastrar e entrar</button>
            </form>

            <form class="panel auth-panel stadium-panel alt" @onsubmit="LoginAsync" @onsubmit:preventDefault="true">
                <div class="panel-title">
                    <span>02</span>
                    <h2>Login</h2>
                </div>
                <label>
                    E-mail
                    <input type="email" @bind="Login.Email" required autocomplete="email" />
                </label>
                <label>
                    Senha
                    <input type="password" @bind="Login.Senha" required autocomplete="current-password" />
                </label>
                <button class="primary-action" type="submit" disabled="@Busy">Entrar</button>
            </form>
        </section>
    }
    else
    {
        <section class="session-strip">
            <div>
                <span>Sessao ativa</span>
                <strong>@Session.Usuario.Nome</strong>
                <small>@Session.Usuario.Email | expira em @Session.ExpiraEm.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
            <button type="button" @onclick="LogoutAsync" disabled="@Busy">Sair</button>
        </section>

        <section class="metrics-grid">
            <article>
                <span>Usuarios</span>
                <strong>@Usuarios.Count</strong>
            </article>
            <article>
                <span>Criadores</span>
                <strong>@Criadores.Count</strong>
            </article>
            <article>
                <span>Conteudos</span>
                <strong>@Conteudos.Count</strong>
            </article>
            <article>
                <span>Midias prontas</span>
                <strong>@ConteudosComMidia.Count</strong>
            </article>
        </section>

        <nav class="tabs" aria-label="Areas do painel">
            <button type="button" class="@TabClass("player")" @onclick='() => ActiveSection = "player"'>Player</button>
            <button type="button" class="@TabClass("cine")" @onclick='() => ActiveSection = "cine"'>Cine</button>
            <button type="button" class="@TabClass("conteudos")" @onclick='() => ActiveSection = "conteudos"'>Conteudos</button>
            <button type="button" class="@TabClass("playlists")" @onclick='() => ActiveSection = "playlists"'>Playlists</button>
            <button type="button" class="@TabClass("criadores")" @onclick='() => ActiveSection = "criadores"'>Criadores</button>
            <button type="button" class="@TabClass("usuarios")" @onclick='() => ActiveSection = "usuarios"'>Usuarios</button>
        </nav>

        @if (ActiveSection == "player")
        {
            <section class="player-layout">
                <div class="panel player-stage">
                    <div class="player-topline">
                        <div>
                            <span class="pill">Area de reproducao</span>
                            <h2>@(ConteudoEmReproducao?.Titulo ?? "Escolha uma midia")</h2>
                            <p>@PlayerMessage</p>
                        </div>
                        @if (ReproducaoAtual is not null)
                        {
                            <div class="stream-meta">
                                <span>@MediaKindLabel(ConteudoEmReproducao)</span>
                                <strong>@FormatBytes(ReproducaoAtual.TamanhoBytes)</strong>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(PlayerSource))
                    {
                        @if (IsAudio(ConteudoEmReproducao))
                        {
                            <div class="audio-stage">
                                <div class="audio-art">
                                    <span>@MediaIcon(ConteudoEmReproducao)</span>
                                    <strong>@(ConteudoEmReproducao?.Titulo ?? "Audio")</strong>
                                    <small>@(ConteudoEmReproducao?.Criador?.Nome ?? CriadorNome(ConteudoEmReproducao?.CriadorId ?? 0))</small>
                                </div>
                                <audio class="audio-player" src="@PlayerSource" controls preload="metadata"></audio>
                            </div>
                        }
                        else
                        {
                            <video class="video-player" src="@PlayerSource" controls preload="metadata"></video>
                        }
                    }
                    else
                    {
                        <div class="empty-player">
                            <span class="play-symbol">PLAY</span>
                            <strong>Player aguardando midia</strong>
                            <p>Selecione video, musica ou podcast. O front tenta stream validado e usa o arquivo de midia como fallback.</p>
                        </div>
                    }
                </div>

                <aside class="panel video-rail">
                    <div class="panel-title">
                        <span>Historico</span>
                        <h2>Sua arquibancada</h2>
                    </div>
                    @if (HistoricoPlayer.Count == 0)
                    {
                        <p class="muted">Assista algo pelo Cine ou pelo catalogo para montar seu historico local.</p>
                    }
                    else
                    {
                        @foreach (var conteudo in HistoricoPlayer)
                        {
                            <article class="history-row @(ConteudoEmReproducao?.Id == conteudo.Id ? "active" : string.Empty)">
                                <button type="button" class="history-play" @onclick="() => PrepararReproducaoAsync(conteudo)">
                                    <span>@MediaKindLabel(conteudo)</span>
                                    <strong>@conteudo.Titulo</strong>
                                    <small>@(conteudo.Criador?.Nome ?? CriadorNome(conteudo.CriadorId))</small>
                                </button>
                                <button type="button" class="ghost" @onclick="() => EditarConteudoDoPlayer(conteudo)">Editar</button>
                            </article>
                        }
                    }
                </aside>
            </section>
        }
        else if (ActiveSection == "cine")
        {
            <section class="cine-shell">
                <div class="cine-main">
                    <section class="cine-hero panel">
                        <div>
                            <span class="pill">Cine Paqueta</span>
                            <h2>@(CineDestaque?.Titulo ?? "Vitrine de videos")</h2>
                            <p>
                                Uma area de exibicao estilo streaming para os videos cadastrados. Passe o mouse
                                nos cards para pre-visualizar.
                            </p>
                            <div class="cine-hero-actions">
                                @if (CineDestaque is not null)
                                {
                                    <button type="button" class="primary-action" @onclick="() => PrepararReproducaoAsync(CineDestaque)">Assistir agora</button>
                                }
                            </div>
                        </div>
                    </section>

                    <section class="cine-filter-panel panel">
                        <div class="filter-copy">
                            <span class="pill">Filtros</span>
                            <h2>Escolha a proxima sessao</h2>
                        </div>
                        <label>
                            Buscar
                            <input @bind="CineBusca" @bind:event="oninput" placeholder="Titulo ou criador" />
                        </label>
                        <label>
                            Criador
                            <select @bind="CineCriadorId">
                                <option value="0">Todos</option>
                                @foreach (var criador in Criadores)
                                {
                                    <option value="@criador.Id">@criador.Nome</option>
                                }
                            </select>
                        </label>
                        <div class="filter-chips" aria-label="Filtro de disponibilidade">
                            <button type="button" class="@FilterChipClass("todos")" @onclick='() => SetCineCategoria("todos")'>Todos</button>
                            <button type="button" class="@FilterChipClass("prontos")" @onclick='() => SetCineCategoria("prontos")'>Prontos</button>
                            <button type="button" class="@FilterChipClass("com-arquivo")" @onclick='() => SetCineCategoria("com-arquivo")'>Com arquivo</button>
                            <button type="button" class="@FilterChipClass("sem-arquivo")" @onclick='() => SetCineCategoria("sem-arquivo")'>Sem arquivo</button>
                        </div>
                    </section>

                    <section class="cine-row">
                        <div class="cine-row-head">
                            <div>
                                <span class="eyebrow">Catalogo de videos</span>
                                <h2>Em cartaz</h2>
                            </div>
                            <span>@CineVideosFiltrados.Count video(s)</span>
                        </div>

                        @if (CineVideosFiltrados.Count == 0)
                        {
                            <div class="panel cine-empty">
                                <strong>Nenhum video encontrado</strong>
                                <p>Cadastre conteudos do tipo video ou ajuste os filtros acima.</p>
                            </div>
                        }
                        else
                        {
                            <div class="cine-grid">
                                @foreach (var video in CineVideosPagina)
                                {
                                    var previewId = PreviewId(video);
                                    var previewSource = CinePreviewSource(video);
                                    <article class="cine-card" style="@CineCardStyle(video)" @onmouseenter="() => IniciarPreviewAsync(previewId)" @onmouseleave="() => PararPreviewAsync(previewId)">
                                        <div class="cine-cover">
                                            @if (!string.IsNullOrWhiteSpace(previewSource))
                                            {
                                                <video id="@previewId" class="cine-preview" src="@previewSource" muted loop playsinline preload="metadata" data-thumbnail-video="true"></video>
                                            }
                                            else
                                            {
                                                <div class="cine-no-preview">
                                                    <span>Sem midia</span>
                                                </div>
                                            }
                                            <div class="cine-poster">
                                                <span>PS</span>
                                                <strong>@video.Titulo</strong>
                                                <small>@(video.Criador?.Nome ?? CriadorNome(video.CriadorId))</small>
                                            </div>
                                        </div>
                                        <div class="cine-card-body">
                                            <div>
                                                <span class="pill">@video.Tipo</span>
                                                <h3>@video.Titulo</h3>
                                                <p>@(video.Criador?.Nome ?? CriadorNome(video.CriadorId))</p>
                                            </div>
                                            <div class="card-actions">
                                                <button type="button" class="watch-action" @onclick="() => PrepararReproducaoAsync(video)">Assistir</button>
                                                @if (!string.IsNullOrWhiteSpace(MediaUrl(video)))
                                                {
                                                    <a class="media-link" href="@MediaUrl(video)" target="_blank">Midia</a>
                                                }
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                            @if (CineTotalPages > 1)
                            {
                                <div class="pagination-bar">
                                    <button type="button" @onclick="() => MudarPaginaCine(-1)" disabled="@(CineCurrentPage <= 1)">Anterior</button>
                                    <span>Pagina @CineCurrentPage de @CineTotalPages</span>
                                    <button type="button" @onclick="() => MudarPaginaCine(1)" disabled="@(CineCurrentPage >= CineTotalPages)">Proxima</button>
                                </div>
                            }
                        }
                    </section>
                </div>
            </section>
        }
        else if (ActiveSection == "conteudos")
        {
            <section class="workspace">
                <EditorPanel Title="Conteudo" Badge="Studio" ActiveMode="@ConteudoMode" ActiveModeChanged="AlterarConteudoModeAsync" HasEdit="@(ConteudoEditId > 0)" CreateLabel="Upload" EditLabel="Editar">
                    @if (ConteudoMode == "create")
                    {
                        <form class="resource-form" @onsubmit="CriarConteudoAsync" @onsubmit:preventDefault="true">
                            <label>
                                Titulo
                                <input @bind="ConteudoNovo.Titulo" required />
                            </label>
                            <label>
                                Tipo
                                <select @bind="ConteudoNovo.Tipo">
                                    <option value="video">video</option>
                                    <option value="musica">musica</option>
                                    <option value="podcast">podcast</option>
                                </select>
                            </label>
                            <label>
                                Criador
                                <select @bind="ConteudoNovo.CriadorId" required>
                                    <option value="0">Selecione</option>
                                    @foreach (var criador in Criadores)
                                    {
                                        <option value="@criador.Id">@criador.Nome</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Arquivo
                                <InputFile OnChange="SelecionarArquivoConteudo" />
                                <small>@(ArquivoConteudoNome ?? "Nenhum arquivo selecionado")</small>
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || ConteudoNovo.CriadorId == 0)">Enviar para o catalogo</button>
                        </form>
                    }
                    else
                    {
                        <form class="resource-form" @onsubmit="AtualizarConteudoAsync" @onsubmit:preventDefault="true">
                            <label>
                                ID
                                <input value="@ConteudoEditId" disabled />
                            </label>
                            <label>
                                Titulo
                                <input @bind="ConteudoEdit.Titulo" required disabled="@(ConteudoEditId == 0)" />
                            </label>
                            <label>
                                Tipo
                                <select @bind="ConteudoEdit.Tipo" disabled="@(ConteudoEditId == 0)">
                                    <option value="video">video</option>
                                    <option value="musica">musica</option>
                                    <option value="podcast">podcast</option>
                                </select>
                            </label>
                            <label>
                                Criador
                                <select @bind="ConteudoEdit.CriadorId" disabled="@(ConteudoEditId == 0)">
                                    <option value="0">Selecione</option>
                                    @foreach (var criador in Criadores)
                                    {
                                        <option value="@criador.Id">@criador.Nome</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Arquivo salvo
                                <input @bind="ConteudoEdit.ArquivoMidia" disabled="@(ConteudoEditId == 0)" />
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || ConteudoEditId == 0)">Salvar alteracoes</button>
                        </form>
                    }
                </EditorPanel>

                <div class="cards-grid media-catalog">
                    @foreach (var conteudo in ConteudosPagina)
                    {
                        <article class="data-card media-card">
                            <div>
                                <span class="pill">@conteudo.Tipo</span>
                                <h3>@conteudo.Titulo</h3>
                                <p>@(conteudo.Criador?.Nome ?? CriadorNome(conteudo.CriadorId))</p>
                            </div>
                            <div class="status-line">
                                <span class="status-dot @(IsPlayableMedia(conteudo) ? "ok" : string.Empty)"></span>
                                <small>@(IsPlayableMedia(conteudo) ? "Pronto para player" : "Catalogado")</small>
                            </div>
                            <div class="card-actions">
                                @if (IsSupportedMedia(conteudo))
                                {
                                    <button type="button" class="watch-action" @onclick="() => PrepararReproducaoAsync(conteudo)">Reproduzir</button>
                                }
                                @if (!string.IsNullOrWhiteSpace(MediaUrl(conteudo)))
                                {
                                    <a class="media-link" href="@MediaUrl(conteudo)" target="_blank">Abrir midia</a>
                                }
                                <button type="button" @onclick="() => SelecionarConteudo(conteudo)">Editar</button>
                                <button type="button" class="danger" @onclick="() => RemoverConteudoAsync(conteudo.Id)">Remover</button>
                            </div>
                        </article>
                    }
                </div>
                @if (ConteudoTotalPages > 1)
                {
                    <div class="pagination-bar">
                        <button type="button" @onclick="() => MudarPaginaConteudos(-1)" disabled="@(ConteudoCurrentPage <= 1)">Anterior</button>
                        <span>Pagina @ConteudoCurrentPage de @ConteudoTotalPages</span>
                        <button type="button" @onclick="() => MudarPaginaConteudos(1)" disabled="@(ConteudoCurrentPage >= ConteudoTotalPages)">Proxima</button>
                    </div>
                }
            </section>
        }
        else if (ActiveSection == "playlists")
        {
            <section class="workspace">
                <EditorPanel Title="Playlist" Badge="Curadoria" ActiveMode="@PlaylistMode" ActiveModeChanged="AlterarPlaylistModeAsync" HasEdit="@(PlaylistEditId > 0)">
                    @if (PlaylistMode == "create")
                    {
                        <form class="resource-form compact" @onsubmit="CriarPlaylistAsync" @onsubmit:preventDefault="true">
                            <label>
                                Nome
                                <input @bind="PlaylistNova.Nome" required />
                            </label>
                            <label>
                                Usuario dono
                                <select @bind="PlaylistNova.UsuarioId" required>
                                    <option value="0">Selecione</option>
                                    @foreach (var usuario in Usuarios)
                                    {
                                        <option value="@usuario.Id">@usuario.Nome</option>
                                    }
                                </select>
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || PlaylistNova.UsuarioId == 0)">Criar playlist</button>
                        </form>
                    }
                    else
                    {
                        <form class="resource-form compact" @onsubmit="AtualizarPlaylistAsync" @onsubmit:preventDefault="true">
                            <label>
                                ID
                                <input value="@PlaylistEditId" disabled />
                            </label>
                            <label>
                                Nome
                                <input @bind="PlaylistEdit.Nome" required disabled="@(PlaylistEditId == 0)" />
                            </label>
                            <label>
                                Usuario dono
                                <select @bind="PlaylistEdit.UsuarioId" disabled="@(PlaylistEditId == 0)">
                                    <option value="0">Selecione</option>
                                    @foreach (var usuario in Usuarios)
                                    {
                                        <option value="@usuario.Id">@usuario.Nome</option>
                                    }
                                </select>
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || PlaylistEditId == 0)">Salvar playlist</button>
                        </form>
                    }
                </EditorPanel>

                <div class="list-stack">
                    @foreach (var playlist in Playlists)
                    {
                        <article class="panel playlist-card">
                            <div class="row-between">
                                <div>
                                    <span class="pill">playlist #@playlist.Id</span>
                                    <h3>@playlist.Nome</h3>
                                    <p>@UsuarioNome(playlist.UsuarioId) | @playlist.Items.Count item(ns)</p>
                                </div>
                                <div class="card-actions">
                                    <button type="button" @onclick="() => SelecionarPlaylist(playlist)">Editar</button>
                                    <button type="button" class="danger" @onclick="() => RemoverPlaylistAsync(playlist.Id)">Remover</button>
                                </div>
                            </div>

                            <form class="inline-form" @onsubmit="() => AdicionarItemPlaylistAsync(playlist.Id)" @onsubmit:preventDefault="true">
                                <select value="@ConteudoSelecionadoParaPlaylist(playlist.Id)" @onchange="e => DefinirConteudoParaPlaylist(playlist.Id, e.Value)">
                                    <option value="0">Selecione um conteudo</option>
                                    @foreach (var conteudo in Conteudos)
                                    {
                                        <option value="@conteudo.Id">@conteudo.Titulo</option>
                                    }
                                </select>
                                <button type="submit" disabled="@(Busy || Conteudos.Count == 0)">Adicionar item</button>
                            </form>

                            <div class="playlist-items">
                                @foreach (var item in playlist.Items)
                                {
                                    <div>
                                        <span>@(item.Conteudo?.Titulo ?? ConteudoTitulo(item.ConteudoId))</span>
                                        <button type="button" class="danger ghost" @onclick="() => RemoverItemPlaylistAsync(item.Id)">Remover</button>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
        else if (ActiveSection == "criadores")
        {
            <section class="workspace">
                <EditorPanel Title="Criador" Badge="Autor" ActiveMode="@CriadorMode" ActiveModeChanged="AlterarCriadorModeAsync" HasEdit="@(CriadorEditId > 0)">
                    @if (CriadorMode == "create")
                    {
                        <form class="resource-form compact" @onsubmit="CriarCriadorAsync" @onsubmit:preventDefault="true">
                            <label>
                                Nome
                                <input @bind="CriadorNovo.Nome" required />
                            </label>
                            <button class="primary-action" type="submit" disabled="@Busy">Criar criador</button>
                        </form>
                    }
                    else
                    {
                        <form class="resource-form compact" @onsubmit="AtualizarCriadorAsync" @onsubmit:preventDefault="true">
                            <label>
                                ID
                                <input value="@CriadorEditId" disabled />
                            </label>
                            <label>
                                Nome
                                <input @bind="CriadorEdit.Nome" required disabled="@(CriadorEditId == 0)" />
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || CriadorEditId == 0)">Salvar criador</button>
                        </form>
                    }
                </EditorPanel>

                <div class="table-panel">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var criador in Criadores)
                            {
                                <tr>
                                    <td>@criador.Id</td>
                                    <td>@criador.Nome</td>
                                    <td>
                                        <button type="button" @onclick="() => SelecionarCriador(criador)">Editar</button>
                                        <button type="button" class="danger" @onclick="() => RemoverCriadorAsync(criador.Id)">Remover</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
        else
        {
            <section class="workspace">
                <EditorPanel Title="Usuario" Badge="Acesso" ActiveMode="@UsuarioMode" ActiveModeChanged="AlterarUsuarioModeAsync" HasEdit="@(UsuarioEditId > 0)">
                    @if (UsuarioMode == "create")
                    {
                        <form class="resource-form" @onsubmit="CriarUsuarioAsync" @onsubmit:preventDefault="true">
                            <label>
                                Nome
                                <input @bind="UsuarioNovo.Nome" required />
                            </label>
                            <label>
                                E-mail
                                <input type="email" @bind="UsuarioNovo.Email" required />
                            </label>
                            <label>
                                Senha
                                <input type="password" @bind="UsuarioNovo.Senha" required />
                            </label>
                            <button class="primary-action" type="submit" disabled="@Busy">Criar usuario</button>
                        </form>
                    }
                    else
                    {
                        <form class="resource-form" @onsubmit="AtualizarUsuarioAsync" @onsubmit:preventDefault="true">
                            <label>
                                ID
                                <input value="@UsuarioEditId" disabled />
                            </label>
                            <label>
                                Nome
                                <input @bind="UsuarioEdit.Nome" required disabled="@(UsuarioEditId == 0)" />
                            </label>
                            <label>
                                E-mail
                                <input type="email" @bind="UsuarioEdit.Email" required disabled="@(UsuarioEditId == 0)" />
                            </label>
                            <button class="primary-action" type="submit" disabled="@(Busy || UsuarioEditId == 0)">Salvar usuario</button>
                        </form>
                    }
                </EditorPanel>

                <div class="table-panel">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>E-mail</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usuario in Usuarios)
                            {
                                <tr>
                                    <td>@usuario.Id</td>
                                    <td>@usuario.Nome</td>
                                    <td>@usuario.Email</td>
                                    <td>
                                        <button type="button" @onclick="() => SelecionarUsuario(usuario)">Editar</button>
                                        <button type="button" class="danger" @onclick="() => RemoverUsuarioAsync(usuario.Id)">Remover</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="toast @(IsError ? "error" : "success")" role="status">@StatusMessage</div>
    }
</main>

@code {
