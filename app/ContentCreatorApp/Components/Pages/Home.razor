    private List<Conteudo> ConteudosPagina => Paginar(Conteudos, ConteudoCurrentPage);

    private List<Conteudo> HistoricoPlayer => PlayerHistoryIds
        .Select(id => Conteudos.FirstOrDefault(conteudo => conteudo.Id == id))
        .Where(conteudo => conteudo is not null)
        .Cast<Conteudo>()
        .Where(IsSupportedMedia)
        .ToList();

    private string? PlayerHistoryStorageKey => Session is null
        ? null
        : $"{PlayerHistoryStorageBaseKey}.usuario.{Session.Usuario.Id}";

    private string? PlayerSource => BuildPlayerSource(ConteudoEmReproducao);

    private string PlayerMessage
    {
        get
        {
            if (ConteudoEmReproducao is null)
            {
                return "Selecione video, musica ou podcast para iniciar o player.";
            }

            if (ReproducaoAtual is not null && !string.IsNullOrWhiteSpace(ReproducaoAtual.Mensagem))
            {
                return ReproducaoAtual.Mensagem;
