    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        ApiBaseUrl = await Js.InvokeAsync<string?>("localStorage.getItem", ApiBaseStorageKey)
            ?? Configuration["StreamingApi:BaseUrl"]
            ?? ApiBaseUrl;

        var authJson = await Js.InvokeAsync<string?>("localStorage.getItem", AuthStorageKey);
        if (!string.IsNullOrWhiteSpace(authJson))
        {
            Session = System.Text.Json.JsonSerializer.Deserialize<AuthResponse>(
                authJson,
                new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)
                {
                    PropertyNameCaseInsensitive = true
                });

            if (Session is not null)
            {
                await LoadProtectedDataAsync("Sessao restaurada.");
            }
        }

        IsReady = true;
        StateHasChanged();
    }

    private async Task SalvarApiBaseUrlAsync()
    {
        await Js.InvokeVoidAsync("localStorage.setItem", ApiBaseStorageKey, ApiBaseUrl.Trim().TrimEnd('/'));
        SetStatus("Endpoint da API salvo.");
    }

    private async Task CadastrarAsync() =>
        await RunAsync(async () =>
        {
            Session = await Api.CadastrarAsync(ApiBaseUrl, Cadastro);
            ResetarEstadoDeUsuarioAtual();
            await PersistAuthAsync();
            Cadastro = new();
            await LoadProtectedDataAsync("Cadastro realizado e token salvo.");
        });

    private async Task LoginAsync() =>
        await RunAsync(async () =>
        {
            Session = await Api.LoginAsync(ApiBaseUrl, Login);
            ResetarEstadoDeUsuarioAtual();
            await PersistAuthAsync();
            Login = new();
            await LoadProtectedDataAsync("Login realizado e token salvo.");
        });

    private async Task LogoutAsync()
    {
        Session = null;
        Usuarios = [];
        Criadores = [];
        Conteudos = [];
        Playlists = [];
        PlayerHistoryIds = [];
        ConteudoEmReproducao = null;
        ReproducaoAtual = null;
        await Js.InvokeVoidAsync("localStorage.removeItem", AuthStorageKey);
        await LimparHistoricoLegadoAsync();
        SetStatus("Sessao encerrada.");
    }

    private async Task LoadProtectedDataAsync(string? successMessage = null) =>
        await RunAsync(async () =>
        {
            if (Session is null)
            {
                return;
            }

            Usuarios = await Api.ListarUsuariosAsync(ApiBaseUrl, Session.Token);
            Criadores = await Api.ListarCriadoresAsync(ApiBaseUrl, Session.Token);
            Conteudos = await Api.ListarConteudosAsync(ApiBaseUrl, Session.Token);
            Playlists = await Api.ListarPlaylistsAsync(ApiBaseUrl, Session.Token);

            PlaylistNova.UsuarioId = Session.Usuario.Id;
            if (ConteudoNovo.CriadorId == 0 && Criadores.Count > 0)
            {
                ConteudoNovo.CriadorId = Criadores[0].Id;
            }

            ConteudoEmReproducao ??= ConteudosComMidia.FirstOrDefault();
            CineDestaque ??= CineVideosFiltrados.FirstOrDefault() ?? CineVideos.FirstOrDefault();
            await RestaurarHistoricoPlayerAsync();
            IsReady = true;
            if (!string.IsNullOrWhiteSpace(successMessage))
            {
                SetStatus(successMessage);
            }
        });

    private async Task PrepararReproducaoAsync(Conteudo conteudo)
    {
        ActiveSection = "player";
        await RunAsync(async () =>
        {
            ConteudoEmReproducao = conteudo;
            CineDestaque = IsVideo(conteudo) ? conteudo : CineDestaque;
            ReproducaoAtual = null;

            if (IsVideo(conteudo))
            {
                try
                {
                    ReproducaoAtual = await Api.ObterReproducaoAsync(ApiBaseUrl, Token, conteudo.Id);
                }
                catch (Exception ex) when (HasMediaFallback(conteudo))
                {
                    SetStatus($"Usando arquivo direto da midia para {conteudo.Titulo}. Detalhe da validacao: {ex.Message}");
                }
            }

            if (string.IsNullOrWhiteSpace(PlayerSource))
            {
                SetError("Este conteudo nao possui URL ou arquivo de midia para o player.");
                return;
            }

            SetStatus($"{MediaKindLabel(conteudo)} pronto: {conteudo.Titulo}.");
            await SalvarHistoricoPlayerAsync(conteudo);
        });
    }

