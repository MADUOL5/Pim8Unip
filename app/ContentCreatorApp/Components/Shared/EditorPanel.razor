<section class="panel editor-panel">
    <div class="editor-head">
        <div class="panel-title">
            <span>@Badge</span>
            <h2>@Title</h2>
        </div>
        <div class="mode-switch" role="tablist" aria-label="@Title">
            <button type="button" class="@ModeClass("create")" @onclick='() => ChangeModeAsync("create")'>@CreateLabel</button>
            <button type="button" class="@ModeClass("edit")" disabled="@(!HasEdit)" @onclick='() => ChangeModeAsync("edit")'>@EditLabel</button>
        </div>
    </div>
    @ChildContent
</section>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Badge { get; set; } = "Form";
    [Parameter] public string CreateLabel { get; set; } = "Criar";
    [Parameter] public string EditLabel { get; set; } = "Editar";
    [Parameter] public string ActiveMode { get; set; } = "create";
    [Parameter] public bool HasEdit { get; set; }
    [Parameter] public EventCallback<string> ActiveModeChanged { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ModeClass(string mode) => ActiveMode == mode ? "active" : string.Empty;

    private async Task ChangeModeAsync(string mode)
    {
        if (mode == "edit" && !HasEdit)
        {
            return;
        }

        ActiveMode = mode;
        await ActiveModeChanged.InvokeAsync(mode);
    }
}
